<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base Dark Theme -->
    <Color x:Key="BgDark">#0D0D1A</Color>
    <Color x:Key="BgMedium">#141428</Color>
    <Color x:Key="BgLight">#1C1C3A</Color>
    <Color x:Key="BgCard">#1E1E3D</Color>
    <Color x:Key="BgHover">#262650</Color>
    <Color x:Key="BgSelected">#2A2A5C</Color>

    <!-- Accent: Teal/Cyan Gradient -->
    <Color x:Key="AccentPrimary">#00D4AA</Color>
    <Color x:Key="AccentSecondary">#00B4D8</Color>
    <Color x:Key="AccentTertiary">#0077B6</Color>
    <Color x:Key="AccentGlow">#00D4AA</Color>

    <!-- Status Colors -->
    <Color x:Key="SuccessColor">#22C55E</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="InfoColor">#3B82F6</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#F0F0F8</Color>
    <Color x:Key="TextSecondary">#9898B0</Color>
    <Color x:Key="TextMuted">#606080</Color>
    <Color x:Key="TextOnAccent">#0D0D1A</Color>

    <!-- Border -->
    <Color x:Key="BorderLight">#2C2C50</Color>
    <Color x:Key="BorderMedium">#3A3A60</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
    <SolidColorBrush x:Key="BgMediumBrush" Color="{StaticResource BgMedium}"/>
    <SolidColorBrush x:Key="BgLightBrush" Color="{StaticResource BgLight}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHover}"/>
    <SolidColorBrush x:Key="BgSelectedBrush" Color="{StaticResource BgSelected}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentPrimary}"/>
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondary}"/>

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentPrimary}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentSecondary}" Offset="0.5"/>
        <GradientStop Color="{StaticResource AccentTertiary}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentButtonGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource AccentPrimary}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentSecondary}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0D0D1A" Offset="0"/>
        <GradientStop Color="#111130" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccent}"/>

    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLight}"/>
    <SolidColorBrush x:Key="BorderMediumBrush" Color="{StaticResource BorderMedium}"/>

</ResourceDictionary>
