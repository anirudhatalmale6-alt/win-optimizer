<Window x:Class="WinOptimizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WinOptimizer.ViewModels"
        Title="WinOptimizer" Width="1100" Height="700" MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}"
        FontFamily="{StaticResource MainFont}"
        Foreground="{StaticResource TextPrimaryBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" CornerRadius="12" GlassFrameThickness="0"
                      ResizeBorderThickness="6" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{StaticResource BgDarkBrush}">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <!-- App Icon -->
                    <Border Width="22" Height="22" CornerRadius="6" Margin="0,0,10,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00D4AA" Offset="0"/>
                                <GradientStop Color="#00B4D8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="W" FontWeight="Bold" FontSize="12" Foreground="#0D0D1A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="WinOptimizer" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text=" v1.0" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" Margin="2,1,0,0"/>
                </StackPanel>

                <!-- Window Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="BtnMinimize" Click="BtnMinimize_Click" Width="46" Height="40"
                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="14" Content="&#x2500;" Cursor="Hand"/>
                    <Button x:Name="BtnMaximize" Click="BtnMaximize_Click" Width="46" Height="40"
                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="11" Content="&#x25A1;" Cursor="Hand"/>
                    <Button x:Name="BtnClose" Click="BtnClose_Click" Width="46" Height="40"
                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="14" Content="&#x2715;" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource SidebarGradient}"
                    BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- System Info Card -->
                    <Border Grid.Row="0" Margin="12,12,12,8" Padding="14" CornerRadius="10"
                            Background="{StaticResource BgCardBrush}" BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding WindowsVersion}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding WindowsBuild}" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                            <Separator Margin="0,8" Background="{StaticResource BorderLightBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBrush}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0}/{1}">
                                                <Binding Path="TotalApplied"/>
                                                <Binding Path="TotalTweaks"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Text="Tweaks Applied" FontSize="10"
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Category Buttons -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource SidebarButton}"
                                            Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Click="CategoryButton_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"/>
                                                <TextBlock FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0}/{1} applied">
                                                            <Binding Path="AppliedCount"/>
                                                            <Binding Path="TotalCount"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding TotalCount}" FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Bottom Actions -->
                    <StackPanel Grid.Row="2" Margin="12,8,12,12">
                        <Button Style="{StaticResource SecondaryButton}" Content="Create Restore Point"
                                Command="{Binding CreateRestorePointCommand}" Margin="0,0,0,6"
                                FontSize="11" Padding="12,8"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="View Log"
                                Click="ShowLog_Click" FontSize="11" Padding="12,8"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Category Header -->
                <Border Grid.Row="0" Padding="24,16,24,12" Background="{StaticResource BgDarkBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding SelectedCategory.Name}" Style="{StaticResource H1}"/>
                                <TextBlock Text="{Binding SelectedCategory.Description}" Style="{StaticResource BodyText}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                <Button Style="{StaticResource SecondaryButton}" Content="Select All"
                                        Command="{Binding SelectAllCommand}" Margin="0,0,6,0"
                                        FontSize="11" Padding="14,7"/>
                                <Button Style="{StaticResource SecondaryButton}" Content="Deselect All"
                                        Command="{Binding DeselectAllCommand}" Margin="0,0,6,0"
                                        FontSize="11" Padding="14,7"/>
                                <Button Style="{StaticResource PrimaryButton}" Content="Apply Selected"
                                        Command="{Binding ApplySelectedCommand}" Margin="0,0,6,0"
                                        FontSize="11" Padding="14,7"/>
                                <Button Style="{StaticResource DangerButton}" Content="Revert Selected"
                                        Command="{Binding RevertSelectedCommand}"
                                        FontSize="11" Padding="14,7"/>
                            </StackPanel>
                        </Grid>

                        <!-- Progress Bar -->
                        <ProgressBar Grid.Row="1" Style="{StaticResource AccentProgressBar}"
                                     Value="{Binding Progress}" Maximum="100" Margin="0,12,0,0"
                                     Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVisibility}}"/>
                    </Grid>
                </Border>

                <!-- Tweaks List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,0,24,16">
                    <ItemsControl ItemsSource="{Binding SelectedCategory.Tweaks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgCardBrush}" CornerRadius="10"
                                        Padding="16,14" Margin="0,0,0,6"
                                        BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Toggle -->
                                        <ToggleButton Grid.Column="0" Style="{StaticResource ToggleSwitch}"
                                                      IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"
                                                      Margin="0,0,14,0"/>

                                        <!-- Info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" Margin="0,3,0,0" MaxWidth="500"/>
                                        </StackPanel>

                                        <!-- Risk Badge -->
                                        <Border Grid.Column="2" CornerRadius="4" Padding="8,3"
                                                VerticalAlignment="Center" Margin="10,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1A22C55E"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Risk}" Value="Medium">
                                                            <Setter Property="Background" Value="#1AF59E0B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Risk}" Value="High">
                                                            <Setter Property="Background" Value="#1AEF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding RiskText}" FontSize="10" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#22C55E"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Risk}" Value="Medium">
                                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Risk}" Value="High">
                                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Status -->
                                        <TextBlock Grid.Column="3" Text="{Binding StatusText}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" MinWidth="80" TextAlignment="Right">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#9898B0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Applied">
                                                            <Setter Property="Foreground" Value="#22C55E"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Error">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource BgMediumBrush}"
                BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0"
                Padding="16,0">
            <Grid>
                <TextBlock Text="{Binding StatusText}" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                            Background="{Binding IsLicensed, Converter={StaticResource LicenseBgConverter}}">
                        <TextBlock FontSize="10" FontWeight="SemiBold"
                                   Foreground="{Binding IsLicensed, Converter={StaticResource LicenseFgConverter}}"
                                   Text="{Binding IsLicensed, Converter={StaticResource LicenseTextConverter}}"/>
                    </Border>
                    <TextBlock Text="{Binding WindowsVersion}" FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Log Overlay -->
        <Border x:Name="LogOverlay" Grid.Row="1" Background="#CC0D0D1A" Visibility="Collapsed">
            <Border Background="{StaticResource BgCardBrush}" CornerRadius="12" Margin="40"
                    Padding="20" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <TextBlock Text="Activity Log" Style="{StaticResource H2}"/>
                        <Button Content="Close" Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Right" Click="CloseLog_Click"
                                FontSize="11" Padding="14,6"/>
                    </Grid>
                    <ListBox Grid.Row="1" Margin="0,12,0,0" ItemsSource="{Binding LogMessages}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                             FontFamily="{StaticResource MonoFont}"/>
                </Grid>
            </Border>
        </Border>

        <!-- Activation Overlay -->
        <Border x:Name="ActivationOverlay" Grid.RowSpan="3" Background="#EE0D0D1A" Visibility="Collapsed">
            <Border Background="{StaticResource BgCardBrush}" CornerRadius="16"
                    Width="420" Height="320" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="32" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1">
                <StackPanel VerticalAlignment="Center">
                    <!-- Logo -->
                    <Border Width="48" Height="48" CornerRadius="12" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00D4AA" Offset="0"/>
                                <GradientStop Color="#00B4D8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="W" FontWeight="Bold" FontSize="22" Foreground="#0D0D1A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Activate WinOptimizer" Style="{StaticResource H2}"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Enter your license key to continue" Style="{StaticResource BodyText}"
                               HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <TextBox x:Name="LicenseKeyBox" Style="{StaticResource ModernTextBox}"
                             FontFamily="{StaticResource MonoFont}" FontSize="12"
                             MaxLength="500" TextWrapping="Wrap" Height="60" AcceptsReturn="True"/>

                    <TextBlock x:Name="ActivationError" Foreground="{StaticResource DangerBrush}"
                               FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>

                    <Button Style="{StaticResource PrimaryButton}" Content="Activate"
                            Click="ActivateButton_Click" Margin="0,16,0,0" Width="200"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
