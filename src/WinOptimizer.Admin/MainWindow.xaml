<Window x:Class="WinOptimizer.Admin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WinOptimizer.Admin.ViewModels"
        Title="WinOptimizer - License Admin" Width="900" Height="650"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D1A" Foreground="#F0F0F8"
        FontFamily="Segoe UI Variable, Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="BgCard" Color="#1E1E3D"/>
        <SolidColorBrush x:Key="BgLight" Color="#1C1C3A"/>
        <SolidColorBrush x:Key="Border" Color="#2C2C50"/>
        <SolidColorBrush x:Key="Accent" Color="#00D4AA"/>
        <SolidColorBrush x:Key="TextSec" Color="#9898B0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#606080"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00D4AA" Offset="0"/>
                            <GradientStop Color="#00B4D8" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="W" FontWeight="Bold" FontSize="16" Foreground="#0D0D1A"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel>
                    <TextBlock Text="License Administration" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Generate, manage and revoke HWID-locked license keys"
                               FontSize="12" Foreground="{StaticResource TextSec}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Generate Section -->
        <Border Grid.Row="1" Background="{StaticResource BgCard}" CornerRadius="12" Padding="20"
                BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,10,8">
                    <TextBlock Text="Hardware ID (HWID)" FontSize="11" Foreground="{StaticResource TextSec}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding HardwareId, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource BgLight}" Foreground="#F0F0F8"
                             BorderBrush="{StaticResource Border}" Padding="10,8" FontSize="12"
                             FontFamily="Cascadia Mono, Consolas"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="0" Margin="10,0,10,8">
                    <TextBlock Text="Issue To (Name/Label)" FontSize="11" Foreground="{StaticResource TextSec}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding IssuedTo, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource BgLight}" Foreground="#F0F0F8"
                             BorderBrush="{StaticResource Border}" Padding="10,8" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Grid.Row="0" Margin="10,0,0,8" VerticalAlignment="Bottom">
                    <Button Command="{Binding GenerateCommand}" Padding="20,10" FontSize="13"
                            FontWeight="SemiBold" Cursor="Hand" Content="Generate Key"
                            Foreground="#0D0D1A" BorderThickness="0">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00D4AA" Offset="0"/>
                                <GradientStop Color="#00B4D8" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,4,0,0">
                    <CheckBox IsChecked="{Binding HasExpiry}" Foreground="{StaticResource TextSec}"
                              FontSize="12" Content="Set expiry" VerticalContentAlignment="Center"/>
                    <TextBlock Text="  Days:" Foreground="{StaticResource TextSec}" FontSize="12"
                               VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <TextBox Text="{Binding ExpiryDays}" Width="60" Background="{StaticResource BgLight}"
                             Foreground="#F0F0F8" BorderBrush="{StaticResource Border}" Padding="6,4"
                             FontSize="12" IsEnabled="{Binding HasExpiry}"/>
                </StackPanel>

                <Border Grid.Row="2" Grid.ColumnSpan="3" Margin="0,10,0,0"
                        Visibility="{Binding LastGeneratedKey, Converter={StaticResource StringToVis}}"
                        Background="#0A00D4AA" CornerRadius="6" Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="Generated Key (copied to clipboard):" FontSize="10"
                                   Foreground="{StaticResource Accent}"/>
                        <TextBox Text="{Binding LastGeneratedKey, Mode=OneWay}" IsReadOnly="True"
                                 Background="Transparent" Foreground="{StaticResource TextSec}"
                                 BorderThickness="0" FontFamily="Cascadia Mono, Consolas"
                                 FontSize="10" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- License List -->
        <Border Grid.Row="2" Background="{StaticResource BgCard}" CornerRadius="12"
                BorderBrush="{StaticResource Border}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Margin="20,14,20,10">
                    <TextBlock Text="Issued Licenses" FontSize="14" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Copy Key" Command="{Binding CopyKeyCommand}"
                                Padding="12,5" FontSize="11" Margin="0,0,6,0"
                                Background="Transparent" Foreground="{StaticResource TextSec}"
                                BorderBrush="{StaticResource Border}" Cursor="Hand"/>
                        <Button Content="Renew" Command="{Binding RenewCommand}"
                                Padding="12,5" FontSize="11" Margin="0,0,6,0"
                                Background="Transparent" Foreground="{StaticResource Accent}"
                                BorderBrush="{StaticResource Accent}" Cursor="Hand"/>
                        <Button Content="Revoke" Command="{Binding RevokeCommand}"
                                Padding="12,5" FontSize="11" Margin="0,0,6,0"
                                Background="Transparent" Foreground="#F59E0B"
                                BorderBrush="#F59E0B" Cursor="Hand"/>
                        <Button Content="Delete" Command="{Binding DeleteCommand}"
                                Padding="12,5" FontSize="11"
                                Background="Transparent" Foreground="#EF4444"
                                BorderBrush="#EF4444" Cursor="Hand"/>
                    </StackPanel>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Licenses}"
                          SelectedItem="{Binding SelectedLicense}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Background="Transparent" Foreground="#F0F0F8"
                          BorderThickness="0" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource Border}"
                          HeadersVisibility="Column" CanUserResizeColumns="True"
                          SelectionMode="Single" RowBackground="Transparent"
                          AlternatingRowBackground="#14141428" FontSize="12">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource BgLight}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="12,6"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2A2A5C"/>
                                    <Setter Property="Foreground" Value="#F0F0F8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2A2A5C"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Issued To" Binding="{Binding IssuedTo}" Width="140"/>
                        <DataGridTextColumn Header="HWID" Binding="{Binding ShortHwid}" Width="160"/>
                        <DataGridTextColumn Header="Issued" Binding="{Binding IssuedAt, StringFormat=yyyy-MM-dd}" Width="100"/>
                        <DataGridTextColumn Header="Expires" Binding="{Binding ExpiresAt, StringFormat=yyyy-MM-dd, TargetNullValue=Never}" Width="100"/>
                        <DataGridTemplateColumn Header="Status" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StatusText}" FontSize="10" FontWeight="Bold"
                                               Foreground="{Binding StatusColor}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Key (truncated)" Binding="{Binding ShortKey}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" FontSize="11"
                   Foreground="{StaticResource TextSec}" Margin="0,10,0,0"/>
    </Grid>
</Window>
